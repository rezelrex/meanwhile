# Vercel injects this automatically when you connect a Blob store — do not set by hand.
BLOB_READ_WRITE_TOKEN=

# OPTIONAL: lock the site to just the two of you.
# Set this in Vercel (Project → Settings → Environment Variables) to any secret phrase
# you both agree on. Leave it unset and the site is open to anyone with the link.
ROOM_PASSPHRASE=
